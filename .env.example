# 小说生成器配置
# 请复制此文件为 .env 并填入你的 API 信息

# LLM API 配置（兼容 OpenAI 格式）
# 默认使用智谱 GLM 编码套餐
LLM_API_KEY=your-api-key-here
# 编码套餐用 /api/coding/paas/v4，通用资源包用 /api/paas/v4
LLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
LLM_MODEL=glm-4-flash

# 可选：用于大纲生成的高质量模型（留空则使用同一模型）
LLM_PLANNER_MODEL=glm-4.7
# 可选：用于章节写作的模型
LLM_WRITER_MODEL=glm-4-flash

# 可选：章节间延迟（毫秒，默认 2000）
CHAPTER_DELAY_MS=2000
# 可选：是否启用流式输出（true/false，默认 false）
LLM_STREAM=false
# 可选：Agent 决策使用的模型（不设置则使用默认策略，不调用LLM）
# LLM_AGENT_MODEL=glm-4-flash
# 可选：Dashboard 访问令牌（留空则无认证，建议设置）
# DASHBOARD_TOKEN=your-secret-token
